<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FlipsiForge.Desktop.ViewModels"
             x:Class="FlipsiForge.Desktop.Views.ModelRepoView"
             x:CompileBindings="False"
             Background="Transparent">

    <UserControl.DataContext>
        <vm:ModelRepoViewModel />
    </UserControl.DataContext>

    <!-- Keine lokalen Styles - globale App.axaml Styles (.bento-card, .badge, Button, TextBox) greifen. -->

    <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="16">

        <!-- Header (TechFlipsi: ember header, Space Grotesk) -->
        <Border Grid.Row="0" Background="#0a0a0f" CornerRadius="12" Padding="16,12"
                BorderBrush="#15ff6600" BorderThickness="1" Margin="0,0,0,10">
            <TextBlock Text="🌐 Model-Repository" FontFamily="Space Grotesk, sans-serif"
                       Foreground="#ff6600" FontWeight="Bold"
                       FontSize="20" VerticalAlignment="Center" />
        </Border>

        <!-- Toolbar: Suche + Kategorie-Badges -->
        <StackPanel Grid.Row="1" Spacing="8" Margin="0,0,0,10">
            <!-- Suchzeile -->
            <Grid ColumnDefinitions="*,Auto">
                <TextBox Grid.Column="0" Text="{Binding SearchText}" Watermark="Modell suchen... (Name oder Designer)"
                         KeyUp="SearchBox_KeyUp" />
                <Button Grid.Column="1" Classes="primary" Content="🔍 Suchen"
                        Command="{Binding SearchCommand}"
                        CommandParameter="{Binding SearchText}"
                        Margin="8,0,0,0" />
            </Grid>

            <!-- Kategorie-Filter als Badges -->
            <ItemsControl ItemsSource="{Binding CategoryBadges}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:ModelCategoryBadgeVm}">
                        <Button Classes="badge" Content="{Binding Label}"
                                Command="{Binding $parent[UserControl].DataContext.ApplyCategoryCommand}"
                                CommandParameter="{Binding SortMode}"
                                Margin="0,0,8,0" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>

        <!-- Modelle-Grid (Bento-Style Cards) -->
        <ScrollViewer Grid.Row="2" HorizontalScrollBarVisibility="Disabled">
            <Panel>
                <ItemsControl ItemsSource="{Binding FilteredModels}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" ItemWidth="240" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:ModelCardVm}">
                            <Border Classes="bento-card" Margin="0,0,16,16" Width="220"
                                    PointerReleased="Card_Click">
                                <StackPanel Orientation="Vertical" Spacing="10">

                                    <!-- Thumbnail: Image ODER Emoji-Platzhalter -->
                                    <Border Height="120" Background="#050507" CornerRadius="12"
                                            BorderBrush="#18181f" BorderThickness="1"
                                            HorizontalAlignment="Stretch"
                                            ClipToBounds="True">
                                        <Panel>
                                            <!-- Image (wenn ThumbnailUrl vorhanden) -->
                                            <Image Source="{Binding ThumbnailUrl}"
                                                   Stretch="UniformToFill"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            <!-- Emoji-Platzhalter (wenn kein Image geladen) -->
                                            <TextBlock Text="{Binding Emoji}" FontSize="56"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Panel>
                                    </Border>

                                    <!-- Name + Designer -->
                                    <StackPanel Orientation="Vertical" Spacing="2">
                                        <TextBlock Text="{Binding Name}" FontFamily="Space Grotesk, sans-serif"
                                                   FontSize="14" FontWeight="SemiBold" Foreground="#e8e8ed"
                                                   TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding Designer}" FontFamily="Inter, sans-serif"
                                                   FontSize="11" Foreground="#7a7a8a"
                                                   TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>

                                    <!-- Likes + Downloads -->
                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <TextBlock Text="❤️" FontSize="11" VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding LikesDisplay}" FontFamily="Space Grotesk, sans-serif"
                                                       FontSize="11" FontWeight="SemiBold" Foreground="#ff8533"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <TextBlock Text="⬇️" FontSize="11" VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding DownloadsDisplay}" FontFamily="Space Grotesk, sans-serif"
                                                       FontSize="11" FontWeight="SemiBold" Foreground="#7a7a8a"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Quelle-Badge + Im Browser oeffnen Button -->
                                    <Grid ColumnDefinitions="*,Auto">
                                        <Border Grid.Column="0" Classes="badge" HorizontalAlignment="Left">
                                            <TextBlock Text="{Binding Source}" FontFamily="Space Grotesk, sans-serif"
                                                       FontSize="10" FontWeight="SemiBold" Foreground="#ff8533" />
                                        </Border>
                                        <Button Grid.Column="1" Content="🔗" FontSize="11" Padding="6,4"
                                                Command="{Binding $parent[UserControl].DataContext.OpenInBrowserCommand}"
                                                CommandParameter="{Binding}" ToolTip.Tip="Im Browser oeffnen" />
                                    </Grid>

                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Empty State -->
                <Border IsVisible="{Binding FilteredModels.Count, Converter={x:Static vm:ZeroToBoolConverter.Instance}}"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Background="#0c0c10" CornerRadius="20" Padding="40"
                        BorderBrush="#15ff6600" BorderThickness="1" Margin="20">
                    <StackPanel Orientation="Vertical" Spacing="12" HorizontalAlignment="Center">
                        <TextBlock Text="🌐" FontSize="48" HorizontalAlignment="Center" />
                        <TextBlock Text="Keine Modelle gefunden" FontFamily="Space Grotesk, sans-serif"
                                   FontSize="16" FontWeight="SemiBold" Foreground="#e8e8ed"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="Versuche eine andere Suche oder Kategorie."
                                   FontFamily="Inter, sans-serif" FontSize="12" Foreground="#7a7a8a"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>
            </Panel>
        </ScrollViewer>

        <!-- Status-Leiste unten (Loading-Spinner + Status-Text) -->
        <Grid Grid.Row="3" ColumnDefinitions="Auto,*" Margin="0,10,0,0">
            <TextBlock Grid.Column="0" Text="⏳" FontSize="16" VerticalAlignment="Center"
                       IsVisible="{Binding IsLoading}" />
            <TextBlock Grid.Column="1" Text="{Binding StatusText}" FontFamily="Inter, sans-serif"
                       FontSize="12" Foreground="#7a7a8a" VerticalAlignment="Center"
                       Margin="8,0,0,0" />
        </Grid>
    </Grid>
</UserControl>