<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FlipsiForge.Desktop.ViewModels"
             x:Class="FlipsiForge.Desktop.Views.PrinterView"
             x:CompileBindings="False"
             Background="Transparent">

    <UserControl.DataContext>
        <vm:PrinterViewModel />
    </UserControl.DataContext>

    <UserControl.Styles>
        <!-- ===== BENTO CARD ===== -->
        <Style Selector="Border.bento-card">
            <Setter Property="Background" Value="#0c0c10" />
            <Setter Property="BorderBrush" Value="#15ff6600" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="20" />
            <Setter Property="Padding" Value="24" />
            <Setter Property="BoxShadow" Value="0 4 16 #00000022" />
        </Style>
        <Style Selector="Border.bento-card:pointerover">
            <Setter Property="BorderBrush" Value="#40ff6600" />
            <Setter Property="BoxShadow" Value="0 12 40 #00000055" />
        </Style>

        <!-- ===== STATUS DOT ===== -->
        <Style Selector="Ellipse.status-dot">
            <Setter Property="Width" Value="8" />
            <Setter Property="Height" Value="8" />
        </Style>

        <!-- ===== PROTOCOL BADGE ===== -->
        <Style Selector="Border.badge">
            <Setter Property="Background" Value="#18181f" />
            <Setter Property="BorderBrush" Value="#25ff6600" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="8,3" />
        </Style>

        <!-- ===== CARD ACTION BUTTON (pill) ===== -->
        <Style Selector="Button.card-btn">
            <Setter Property="Background" Value="#111116" />
            <Setter Property="BorderBrush" Value="#15ff6600" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Foreground" Value="#ff8533" />
            <Setter Property="FontFamily" Value="Space Grotesk, sans-serif" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="Button.card-btn:pointerover">
            <Setter Property="Background" Value="#18181f" />
            <Setter Property="BorderBrush" Value="#40ff6600" />
            <Setter Property="Foreground" Value="#e8e8ed" />
        </Style>

        <!-- ===== PRIMARY ADD BUTTON ===== -->
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="#ff6600" />
            <Setter Property="BorderBrush" Value="#ff6600" />
            <Setter Property="Foreground" Value="#050507" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="CornerRadius" Value="999" />
        </Style>
        <Style Selector="Button.primary:pointerover">
            <Setter Property="Background" Value="#ff8533" />
        </Style>

        <!-- ===== DANGER BUTTON ===== -->
        <Style Selector="Button.danger">
            <Setter Property="Background" Value="#22ef4444" />
            <Setter Property="BorderBrush" Value="#25ef4444" />
            <Setter Property="Foreground" Value="#ef4444" />
            <Setter Property="CornerRadius" Value="999" />
        </Style>
        <Style Selector="Button.danger:pointerover">
            <Setter Property="Background" Value="#40ef4444" />
            <Setter Property="Foreground" Value="#ff8888" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*" Margin="16">
        <!-- ===== HEADER / TOOLBAR ===== -->
        <Border Grid.Row="0" Background="#0a0a0f" CornerRadius="12" Padding="16,12"
                BorderBrush="#15ff6600" BorderThickness="1" Margin="0,0,0,10">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <TextBlock Grid.Column="0" Text="🖨️ Drucker" FontFamily="Space Grotesk, sans-serif"
                           Foreground="#ff6600" FontWeight="Bold"
                           FontSize="18" VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" Text="{Binding Printers.Count, StringFormat='{}{0} Drucker'}"
                           FontFamily="Space Grotesk, sans-serif"
                           Foreground="#7a7a8a" FontSize="12" VerticalAlignment="Center" Margin="16,0,0,0" />
                <Button Grid.Column="2" Classes="primary" Content="+ Drucker hinzufügen"
                        Command="{Binding AddCommand}" />
            </Grid>
        </Border>

        <!-- ===== PRINTER CARDS (WrapPanel) ===== -->
        <ScrollViewer Grid.Row="1" Padding="0,0,16,16" HorizontalScrollBarVisibility="Disabled">
            <Panel>
                <ItemsControl ItemsSource="{Binding Printers}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" ItemWidth="400" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:PrinterRowVm}">
                            <Border Classes="bento-card" Margin="0,0,16,16" Width="380">
                                <StackPanel Orientation="Vertical" Spacing="14">

                                    <!-- ===== CARD HEADER: Name + Protocol Badge ===== -->
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <TextBlock Text="🖨️" FontSize="24" VerticalAlignment="Center" />
                                        <StackPanel Orientation="Vertical" Spacing="2">
                                            <TextBlock Text="{Binding Display}" FontFamily="Space Grotesk, sans-serif"
                                                       FontSize="16" FontWeight="SemiBold" Foreground="#e8e8ed" />
                                            <Border Classes="badge" HorizontalAlignment="Left">
                                                <TextBlock Text="{Binding ProtocolDisplay}" FontFamily="Space Grotesk, sans-serif"
                                                           FontSize="10" FontWeight="SemiBold" Foreground="#ff8533" />
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- ===== STATUS ROW ===== -->
                                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,2">
                                        <Ellipse Classes="status-dot" Fill="#55555f" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding StatusGlyph}" FontFamily="Space Grotesk, sans-serif"
                                                   FontSize="12" FontWeight="SemiBold" Foreground="#e8e8ed"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>

                                    <!-- ===== DETAILS ===== -->
                                    <Border BorderBrush="#15ff6600" BorderThickness="0,1,0,0" Padding="0,12,0,0" Margin="0,4">
                                        <StackPanel Orientation="Vertical" Spacing="8">
                                            <!-- IP / USB -->
                                            <Grid ColumnDefinitions="80,*">
                                                <TextBlock Grid.Column="0" Text="IP / USB" FontFamily="Space Grotesk, sans-serif"
                                                           FontSize="11" FontWeight="SemiBold" Foreground="#55555f"
                                                           VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="1" Text="{Binding IpUsb}" FontFamily="Inter, sans-serif"
                                                           FontSize="13" Foreground="#e8e8ed"
                                                           VerticalAlignment="Center" />
                                            </Grid>
                                            <!-- Düse -->
                                            <Grid ColumnDefinitions="80,*">
                                                <TextBlock Grid.Column="0" Text="Düse" FontFamily="Space Grotesk, sans-serif"
                                                           FontSize="11" FontWeight="SemiBold" Foreground="#55555f"
                                                           VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="1" Text="{Binding Nozzle}" FontFamily="Inter, sans-serif"
                                                           FontSize="13" Foreground="#e8e8ed"
                                                           VerticalAlignment="Center" />
                                            </Grid>
                                            <!-- Bauvolumen -->
                                            <Grid ColumnDefinitions="80,*">
                                                <TextBlock Grid.Column="0" Text="Bauvolumen" FontFamily="Space Grotesk, sans-serif"
                                                           FontSize="11" FontWeight="SemiBold" Foreground="#55555f"
                                                           VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="1" Text="{Binding BuildVolume}" FontFamily="Inter, sans-serif"
                                                           FontSize="13" Foreground="#e8e8ed"
                                                           VerticalAlignment="Center" />
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <!-- ===== ACTION BUTTONS (zentriert, pill-shaped) ===== -->
                                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center" Margin="0,4">
                                        <Button Classes="card-btn" Content="🔗 Testen"
                                                Command="{Binding $parent[UserControl].DataContext.TestConnectionCommand}"
                                                CommandParameter="{Binding}" />
                                        <Button Classes="card-btn" Content="✎ Bearbeiten"
                                                Command="{Binding $parent[UserControl].DataContext.EditCommand}"
                                                CommandParameter="{Binding}" />
                                        <Button Classes="danger" Content="✕ Löschen"
                                                Command="{Binding $parent[UserControl].DataContext.DeleteCommand}"
                                                CommandParameter="{Binding}" />
                                    </StackPanel>

                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- ===== EMPTY STATE: keine Drucker ===== -->
                <Border IsVisible="{Binding Printers.Count, Converter={x:Static vm:ZeroToBoolConverter.Instance}}"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Background="#0c0c10" CornerRadius="20" Padding="40"
                        BorderBrush="#15ff6600" BorderThickness="1" Margin="20">
                    <StackPanel Orientation="Vertical" Spacing="12" HorizontalAlignment="Center">
                        <TextBlock Text="🖨️" FontSize="48" HorizontalAlignment="Center" />
                        <TextBlock Text="Keine Drucker konfiguriert" FontFamily="Space Grotesk, sans-serif"
                                   FontSize="16" FontWeight="SemiBold" Foreground="#e8e8ed"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="Klicke auf „+ Drucker hinzufügen“ um deinen ersten 3D-Drucker einzurichten."
                                   FontFamily="Inter, sans-serif" FontSize="12" Foreground="#7a7a8a"
                                   TextWrapping="Wrap" TextAlignment="Center" MaxWidth="300" />
                    </StackPanel>
                </Border>
            </Panel>
        </ScrollViewer>
    </Grid>
</UserControl>