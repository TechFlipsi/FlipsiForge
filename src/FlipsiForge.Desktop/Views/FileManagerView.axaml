<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FlipsiForge.Desktop.ViewModels"
             x:Class="FlipsiForge.Desktop.Views.FileManagerView"
             x:CompileBindings="False"
             Background="Transparent">

    <UserControl.DataContext>
        <vm:FileManagerViewModel />
    </UserControl.DataContext>

    <!-- Keine lokalen Styles mehr — globale Styles aus App.axaml greifen automatisch.
         Bento-Card-Klassen (.bento-sm, .badge) und Button/TextBox/ComboBox globale Styles. -->

    <Grid RowDefinitions="Auto,Auto,*" Margin="16">

        <!-- Header (TechFlipsi: ember header, Space Grotesk) -->
        <Border Grid.Row="0" Background="#0a0a0f" CornerRadius="12" Padding="16,12"
                BorderBrush="#15ff6600" BorderThickness="1" Margin="0,0,0,10">
            <Grid ColumnDefinitions="Auto,*">
                <TextBlock Grid.Column="0" Text="📁 Datei-Manager" FontFamily="Space Grotesk, sans-serif"
                           Foreground="#ff6600" FontWeight="Bold"
                           FontSize="18" VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" Text="{Binding FilteredFiles.Count, StringFormat='{}{0} Dateien'}"
                           FontFamily="Space Grotesk, sans-serif"
                           Foreground="#7a7a8a" FontSize="12" VerticalAlignment="Center" Margin="16,0,0,0" />
            </Grid>
        </Border>

        <!-- Toolbar: Filter-Badges + Suche + Sort/View -->
        <StackPanel Grid.Row="1" Spacing="8" Margin="0,0,0,10">
            <!-- Filter-Badges (globale .badge Border-Klasse via Button.badge) -->
            <ItemsControl ItemsSource="{Binding FilterBadges}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:FilterBadgeVm}">
                        <Button Classes="badge" Content="{Binding Display}"
                                Command="{Binding $parent[UserControl].DataContext.ApplyFilterCommand}"
                                CommandParameter="{Binding Key}" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Suche + Toolbar -->
            <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto">
                <TextBox Grid.Column="0" Text="{Binding SearchText}"
                         PlaceholderText="Suche... (Dateiname + 🤖 KI-Suche automatisch)"
                         KeyUp="SearchBox_KeyUp" />
                <Button Grid.Column="1" Content="🔍" Command="{Binding SearchCommand}" Margin="6,0,0,0" />
                <ComboBox Grid.Column="2" x:Name="SortCombo" ItemsSource="{Binding SortOptions}"
                          SelectedItem="{Binding SelectedSort}" Margin="6,0,0,0"
                          SelectionChanged="SortCombo_SelectionChanged" />
                <Button Grid.Column="3" Content="📋 List" Margin="6,0,0,0" Click="ListBtn_Click" />
                <Button Grid.Column="4" Content="▦ Grid" Margin="6,0,0,0" Click="GridBtn_Click" />
            </Grid>
        </StackPanel>

        <!-- Datei-Liste: LIST-Modus (bento-sm Container) -->
        <Border Grid.Row="2" Classes="bento-sm" Padding="0" IsVisible="{Binding !IsGrid}">
            <ScrollViewer>
                <ItemsControl ItemsSource="{Binding FilteredFiles}" Background="Transparent">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:FileRowVm}">
                            <Border Background="Transparent" BorderBrush="#15ff6600" BorderThickness="0,0,0,1"
                                    Padding="12,8">
                                <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto,Auto">
                                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" Foreground="#e8e8ed" VerticalAlignment="Center"
                                                   FontSize="14" />
                                        <Border Classes="badge"
                                                IsVisible="{Binding IsAiHit}">
                                            <TextBlock Text="🤖 KI" Foreground="#050507" FontSize="10" FontWeight="Bold" />
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{Binding SizeDisplay}" Foreground="#7a7a8a"
                                               FontSize="12" VerticalAlignment="Center" Margin="0,0,16,0" />
                                    <TextBlock Grid.Column="2" Text="{Binding ModifiedDisplay}" Foreground="#7a7a8a"
                                               FontSize="12" VerticalAlignment="Center" Margin="0,0,16,0" />
                                    <TextBlock Grid.Column="3" Text="{Binding OpenCount, StringFormat='×{0}'}"
                                               Foreground="#55555f" FontSize="12" VerticalAlignment="Center"
                                               Margin="0,0,16,0" />
                                    <Button Grid.Column="4" Content="{Binding FavoriteGlyph}"
                                            Background="Transparent" Foreground="#ff6600" Padding="6,2"
                                            FontSize="16" BorderThickness="0"
                                            Command="{Binding $parent[UserControl].DataContext.ToggleFavoriteCommand}"
                                            CommandParameter="{Binding}" />
                                    <Button Grid.Column="5" Content="Öffnen"
                                            Margin="8,0,0,0"
                                            Command="{Binding $parent[UserControl].DataContext.OpenCommand}"
                                            CommandParameter="{Binding}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Datei-Liste: GRID-Modus (bento-sm Container) -->
        <Border Grid.Row="2" Classes="bento-sm" Padding="0" IsVisible="{Binding IsGrid}">
            <ScrollViewer>
                <ItemsControl ItemsSource="{Binding FilteredFiles}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:FileRowVm}">
                            <Border Width="180" Height="220" Margin="6"
                                    Background="#111116" CornerRadius="12" Padding="10"
                                    BorderBrush="#15ff6600" BorderThickness="1">
                                <StackPanel Spacing="4">
                                    <Border Height="120" Background="#050507" CornerRadius="8" BorderBrush="#18181f" BorderThickness="1">
                                        <TextBlock Text="🖼️" FontSize="40" HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" Foreground="#55555f" />
                                    </Border>
                                    <TextBlock Text="{Binding Name}" Foreground="#e8e8ed" FontSize="12"
                                               TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding SizeDisplay}" Foreground="#7a7a8a" FontSize="11" />
                                    <Button Content="{Binding FavoriteGlyph}"
                                            Background="Transparent" Foreground="#ff6600" Padding="4,2"
                                            FontSize="14" HorizontalAlignment="Right" BorderThickness="0"
                                            Command="{Binding $parent[UserControl].DataContext.ToggleFavoriteCommand}"
                                            CommandParameter="{Binding}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Empty State (nur wenn Files.Count == 0) -->
        <Border Grid.Row="2" Background="Transparent" IsVisible="{Binding Files.Count, Converter={x:Static vm:ZeroToBoolConverter.Instance}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10">
                <TextBlock Text="📁" FontSize="60" HorizontalAlignment="Center" Foreground="#55555f" />
                <TextBlock Text="Keine Dateien gefunden" FontFamily="Space Grotesk, sans-serif"
                           Foreground="#7a7a8a" FontSize="16"
                           HorizontalAlignment="Center" />
                <TextBlock Text="Ordner in den Einstellungen → Datei-Manager hinzufügen"
                           FontFamily="Inter, sans-serif" Foreground="#55555f" FontSize="12"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>