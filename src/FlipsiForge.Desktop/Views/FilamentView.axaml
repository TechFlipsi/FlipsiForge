<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FlipsiForge.Desktop.ViewModels"
             x:Class="FlipsiForge.Desktop.Views.FilamentView"
             x:CompileBindings="False"
             Background="Transparent">

    <UserControl.DataContext>
        <vm:FilamentViewModel />
    </UserControl.DataContext>

    <UserControl.Styles>
        <!-- ===== BENTO CARD ===== -->
        <Style Selector="Border.bento-card">
            <Setter Property="Background" Value="#0c0c10" />
            <Setter Property="BorderBrush" Value="#15ff6600" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="20" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="BoxShadow" Value="0 4px 16px #00000022" />
            <Setter Property="ClipToBounds" Value="True" />
        </Style>
        <Style Selector="Border.bento-card:pointerover">
            <Setter Property="BorderBrush" Value="#40ff6600" />
            <Setter Property="BoxShadow" Value="0 12px 40px #00000055" />
        </Style>

        <!-- ===== CARD ACTION BUTTON (pill) ===== -->
        <Style Selector="Button.card-btn">
            <Setter Property="Background" Value="#111116" />
            <Setter Property="BorderBrush" Value="#15ff6600" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Foreground" Value="#ff8533" />
            <Setter Property="FontFamily" Value="Space Grotesk, sans-serif" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="Button.card-btn:pointerover">
            <Setter Property="Background" Value="#18181f" />
            <Setter Property="BorderBrush" Value="#40ff6600" />
            <Setter Property="Foreground" Value="#e8e8ed" />
        </Style>

        <!-- ===== PRIMARY ADD BUTTON ===== -->
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="#ff6600" />
            <Setter Property="BorderBrush" Value="#ff6600" />
            <Setter Property="Foreground" Value="#050507" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="CornerRadius" Value="999" />
        </Style>
        <Style Selector="Button.primary:pointerover">
            <Setter Property="Background" Value="#ff8533" />
        </Style>

        <!-- ===== DANGER BUTTON ===== -->
        <Style Selector="Button.danger">
            <Setter Property="Background" Value="#22ef4444" />
            <Setter Property="BorderBrush" Value="#25ef4444" />
            <Setter Property="Foreground" Value="#ef4444" />
            <Setter Property="CornerRadius" Value="999" />
        </Style>
        <Style Selector="Button.danger:pointerover">
            <Setter Property="Background" Value="#40ef4444" />
            <Setter Property="Foreground" Value="#ff8888" />
        </Style>

        <!-- ===== WEIGHT PROGRESS BAR ===== -->
        <Style Selector="ProgressBar.weight-bar">
            <Setter Property="Height" Value="6" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Background" Value="#111116" />
            <Setter Property="Foreground" Value="#22c55e" />
            <Setter Property="MinHeight" Value="6" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*" Margin="16">
        <!-- ===== HEADER / TOOLBAR ===== -->
        <Border Grid.Row="0" Background="#0a0a0f" CornerRadius="12" Padding="16,12"
                BorderBrush="#15ff6600" BorderThickness="1" Margin="0,0,0,10">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <TextBlock Grid.Column="0" Text="🧶 Filament" FontFamily="Space Grotesk, sans-serif"
                           Foreground="#ff6600" FontWeight="Bold"
                           FontSize="18" VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" Text="{Binding Spools.Count, StringFormat='{}{0} Spulen'}"
                           FontFamily="Space Grotesk, sans-serif"
                           Foreground="#7a7a8a" FontSize="12" VerticalAlignment="Center" Margin="16,0,0,0" />
                <Button Grid.Column="2" Classes="primary" Content="+ Spule hinzufügen"
                        Command="{Binding AddCommand}" />
            </Grid>
        </Border>

        <!-- ===== SPOOL CARDS (WrapPanel) ===== -->
        <ScrollViewer Grid.Row="1" Padding="0,0,16,16" HorizontalScrollBarVisibility="Disabled">
            <Panel>
                <ItemsControl ItemsSource="{Binding Spools}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" ItemWidth="400" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:SpoolRowVm}">
                            <Border Classes="bento-card" Margin="0,0,16,16" Width="380">
                                <StackPanel Orientation="Vertical" Spacing="0">

                                    <!-- ===== COLOR BAR (volle Breite, oben — Spoolman-Style) ===== -->
                                    <Border Height="8" Background="{Binding ColorHex}" />

                                    <!-- ===== CARD BODY ===== -->
                                    <StackPanel Orientation="Vertical" Spacing="14" Margin="24,16,24,20">

                                        <!-- ===== CARD HEADER: Großer Farbswatch + Brand + Material ===== -->
                                        <StackPanel Orientation="Horizontal" Spacing="14">
                                            <!-- Großer runder Farbswatch mit Glow in Filamentfarbe -->
                                            <Border Width="52" Height="52" CornerRadius="14"
                                                    Background="{Binding ColorHex}"
                                                    BorderBrush="#30ffffff" BorderThickness="2"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="🧶" FontSize="20" HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" Opacity="0.5" />
                                            </Border>
                                            <StackPanel Orientation="Vertical" Spacing="3" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Brand}" FontFamily="Space Grotesk, sans-serif"
                                                           FontSize="16" FontWeight="SemiBold" Foreground="#e8e8ed" />
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <Border Background="#18181f" BorderBrush="#25ff6600" BorderThickness="1"
                                                            CornerRadius="8" Padding="8,3">
                                                        <TextBlock Text="{Binding Material}" FontFamily="Space Grotesk, sans-serif"
                                                                   FontSize="10" FontWeight="SemiBold" Foreground="#ff8533" />
                                                    </Border>
                                                    <Border Background="{Binding ColorHex}" BorderBrush="#20ffffff" BorderThickness="1"
                                                            CornerRadius="8" Padding="8,3">
                                                        <TextBlock Text="{Binding ColorName}" FontFamily="Space Grotesk, sans-serif"
                                                                   FontSize="10" FontWeight="SemiBold" Foreground="#050507" />
                                                    </Border>
                                                </StackPanel>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- ===== STATUS ROW ===== -->
                                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,2">
                                            <TextBlock Text="{Binding StatusGlyph}" FontFamily="Space Grotesk, sans-serif"
                                                       FontSize="12" FontWeight="SemiBold" Foreground="#e8e8ed"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>

                                        <!-- ===== WEIGHT PROGRESS (Spoolman-Style) ===== -->
                                        <StackPanel Orientation="Vertical" Spacing="6" Margin="0,4">
                                            <Grid ColumnDefinitions="*,Auto">
                                                <TextBlock Grid.Column="0" Text="Restgewicht" FontFamily="Space Grotesk, sans-serif"
                                                           FontSize="11" FontWeight="SemiBold" Foreground="#55555f"
                                                           VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="1" Text="{Binding Weight}" FontFamily="Space Grotesk, sans-serif"
                                                           FontSize="13" FontWeight="Bold" Foreground="#e8e8ed"
                                                           VerticalAlignment="Center" />
                                            </Grid>
                                            <ProgressBar Classes="weight-bar" Value="{Binding RemainingPercent}" Maximum="100"
                                                         HorizontalAlignment="Stretch" />
                                        </StackPanel>

                                        <!-- ===== DETAILS ===== -->
                                        <Border BorderBrush="#15ff6600" BorderThickness="0,1,0,0" Padding="0,12,0,0" Margin="0,4">
                                            <StackPanel Orientation="Vertical" Spacing="8">
                                                <!-- Durchmesser -->
                                                <Grid ColumnDefinitions="90,*">
                                                    <TextBlock Grid.Column="0" Text="Durchmesser" FontFamily="Space Grotesk, sans-serif"
                                                               FontSize="11" FontWeight="SemiBold" Foreground="#55555f"
                                                               VerticalAlignment="Center" />
                                                    <TextBlock Grid.Column="1" Text="{Binding Diameter}" FontFamily="Inter, sans-serif"
                                                               FontSize="13" Foreground="#e8e8ed"
                                                               VerticalAlignment="Center" />
                                                </Grid>
                                                <!-- Dichte -->
                                                <Grid ColumnDefinitions="90,*">
                                                    <TextBlock Grid.Column="0" Text="Dichte" FontFamily="Space Grotesk, sans-serif"
                                                               FontSize="11" FontWeight="SemiBold" Foreground="#55555f"
                                                               VerticalAlignment="Center" />
                                                    <TextBlock Grid.Column="1" Text="{Binding Density}" FontFamily="Inter, sans-serif"
                                                               FontSize="13" Foreground="#e8e8ed"
                                                               VerticalAlignment="Center" />
                                                </Grid>
                                                <!-- Kosten -->
                                                <Grid ColumnDefinitions="90,*">
                                                    <TextBlock Grid.Column="0" Text="Kosten" FontFamily="Space Grotesk, sans-serif"
                                                               FontSize="11" FontWeight="SemiBold" Foreground="#55555f"
                                                               VerticalAlignment="Center" />
                                                    <TextBlock Grid.Column="1" Text="{Binding Cost}" FontFamily="Inter, sans-serif"
                                                               FontSize="13" Foreground="#e8e8ed"
                                                               VerticalAlignment="Center" />
                                                </Grid>
                                            </StackPanel>
                                        </Border>

                                        <!-- ===== ACTION BUTTONS (zentriert, pill-shaped) ===== -->
                                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center" Margin="0,4">
                                            <Button Classes="card-btn" Content="🔄 Status"
                                                    Command="{Binding $parent[UserControl].DataContext.CycleStatusCommand}"
                                                    CommandParameter="{Binding}" />
                                            <Button Classes="card-btn" Content="✎ Bearbeiten"
                                                    Command="{Binding $parent[UserControl].DataContext.EditCommand}"
                                                    CommandParameter="{Binding}" />
                                            <Button Classes="danger" Content="✕ Löschen"
                                                    Command="{Binding $parent[UserControl].DataContext.DeleteCommand}"
                                                    CommandParameter="{Binding}" />
                                        </StackPanel>

                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- ===== EMPTY STATE: keine Spulen ===== -->
                <Border IsVisible="{Binding Spools.Count, Converter={x:Static vm:ZeroToBoolConverter.Instance}}"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Background="#0c0c10" CornerRadius="20" Padding="40"
                        BorderBrush="#15ff6600" BorderThickness="1" Margin="20">
                    <StackPanel Orientation="Vertical" Spacing="12" HorizontalAlignment="Center">
                        <TextBlock Text="🧶" FontSize="48" HorizontalAlignment="Center" />
                        <TextBlock Text="Keine Spulen konfiguriert" FontFamily="Space Grotesk, sans-serif"
                                   FontSize="16" FontWeight="SemiBold" Foreground="#e8e8ed"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="Klicke auf &quot;+ Spule hinzufügen&quot; um dein erstes Filament einzurichten."
                                   FontFamily="Inter, sans-serif" FontSize="12" Foreground="#7a7a8a"
                                   TextWrapping="Wrap" TextAlignment="Center" MaxWidth="300" />
                    </StackPanel>
                </Border>
            </Panel>
        </ScrollViewer>
    </Grid>
</UserControl>