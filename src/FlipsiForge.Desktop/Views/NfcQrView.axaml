<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FlipsiForge.Desktop.ViewModels"
             x:Class="FlipsiForge.Desktop.Views.NfcQrView"
             x:CompileBindings="False"
             Background="Transparent">

    <UserControl.DataContext>
        <vm:NfcQrViewModel />
    </UserControl.DataContext>

    <UserControl.Styles>
        <!-- ===== BENTO CARD ===== -->
        <Style Selector="Border.bento-card">
            <Setter Property="Background" Value="#0c0c10" />
            <Setter Property="BorderBrush" Value="#15ff6600" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="20" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="BoxShadow" Value="0 4 16 #00000022" />
            <Setter Property="ClipToBounds" Value="True" />
        </Style>
        <Style Selector="Border.bento-card:pointerover">
            <Setter Property="BorderBrush" Value="#40ff6600" />
            <Setter Property="BoxShadow" Value="0 12 40 #00000055" />
        </Style>

        <!-- ===== CARD ACTION BUTTON (pill) ===== -->
        <Style Selector="Button.card-btn">
            <Setter Property="Background" Value="#111116" />
            <Setter Property="BorderBrush" Value="#15ff6600" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Foreground" Value="#ff8533" />
            <Setter Property="FontFamily" Value="Space Grotesk, sans-serif" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="Button.card-btn:pointerover">
            <Setter Property="Background" Value="#18181f" />
            <Setter Property="BorderBrush" Value="#40ff6600" />
            <Setter Property="Foreground" Value="#e8e8ed" />
        </Style>

        <!-- ===== PRIMARY ADD BUTTON ===== -->
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="#ff6600" />
            <Setter Property="BorderBrush" Value="#ff6600" />
            <Setter Property="Foreground" Value="#050507" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="CornerRadius" Value="999" />
        </Style>
        <Style Selector="Button.primary:pointerover">
            <Setter Property="Background" Value="#ff8533" />
        </Style>

        <!-- ===== DANGER BUTTON ===== -->
        <Style Selector="Button.danger">
            <Setter Property="Background" Value="#22ef4444" />
            <Setter Property="BorderBrush" Value="#25ef4444" />
            <Setter Property="Foreground" Value="#ef4444" />
            <Setter Property="CornerRadius" Value="999" />
        </Style>
        <Style Selector="Button.danger:pointerover">
            <Setter Property="Background" Value="#40ef4444" />
            <Setter Property="Foreground" Value="#ff8888" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*" Margin="16">
        <!-- ===== HEADER / TOOLBAR ===== -->
        <Border Grid.Row="0" Background="#0a0a0f" CornerRadius="12" Padding="16,12"
                BorderBrush="#15ff6600" BorderThickness="1" Margin="0,0,0,10">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <TextBlock Grid.Column="0" Text="&#x1F3F7;&#xFE0F; NFC &amp; QR Codes" FontFamily="Space Grotesk, sans-serif"
                           Foreground="#ff6600" FontWeight="Bold"
                           FontSize="18" VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" Text="{Binding Tags.Count, StringFormat='{}{0} Tags'}"
                           FontFamily="Space Grotesk, sans-serif"
                           Foreground="#7a7a8a" FontSize="12" VerticalAlignment="Center" Margin="16,0,0,0" />
                <Button Grid.Column="2" Classes="primary" Content="+ Tag hinzufuegen"
                        Command="{Binding AddCommand}" />
            </Grid>
        </Border>

        <!-- ===== TAG CARDS (WrapPanel) ===== -->
        <ScrollViewer Grid.Row="1" Padding="0,0,16,16" HorizontalScrollBarVisibility="Disabled">
            <Panel>
                <ItemsControl ItemsSource="{Binding Tags}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" ItemWidth="360" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:TagRowVm}">
                            <Border Classes="bento-card" Margin="0,0,16,16" Width="340">
                                <StackPanel Orientation="Vertical" Spacing="14" Margin="24,20">

                                    <!-- ===== CARD HEADER: Code + Type Badge ===== -->
                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                        <TextBlock Text="{Binding Code}" FontFamily="Space Grotesk, sans-serif"
                                                   FontSize="20" FontWeight="Bold" Foreground="#e8e8ed"
                                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>

                                    <!-- ===== TYPE BADGE ===== -->
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Border Background="{Binding TypeBadgeColor}" CornerRadius="999"
                                                Padding="10,3" BorderBrush="#20ffffff" BorderThickness="1">
                                            <TextBlock Text="{Binding TypeGlyph}" FontFamily="Space Grotesk, sans-serif"
                                                       FontSize="11" FontWeight="Bold" Foreground="#050507" />
                                        </Border>
                                    </StackPanel>

                                    <!-- ===== ASSIGNED FILAMENT ===== -->
                                    <Border BorderBrush="#15ff6600" BorderThickness="0,1,0,0" Padding="0,12,0,0" Margin="0,4">
                                        <StackPanel Orientation="Vertical" Spacing="6">
                                            <TextBlock Text="Zugewiesenes Filament" FontFamily="Space Grotesk, sans-serif"
                                                       FontSize="11" FontWeight="SemiBold" Foreground="#55555f" />
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <Border Width="28" Height="28" CornerRadius="8"
                                                        Background="{Binding AssignedSpoolColor}"
                                                        BorderBrush="#20ffffff" BorderThickness="1"
                                                        IsVisible="{Binding IsAssigned}">
                                                    <TextBlock Text="&#x1F9B6;" FontSize="12"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                                               Opacity="0.5" />
                                                </Border>
                                                <TextBlock Text="{Binding AssignedSpoolDisplay}"
                                                           FontFamily="Inter, sans-serif" FontSize="13"
                                                           Foreground="#e8e8ed" VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <!-- ===== ACTION BUTTONS (zentriert, pill-shaped) ===== -->
                                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center" Margin="0,4">
                                        <Button Classes="card-btn" Content="&#x270E; Bearbeiten"
                                                Command="{Binding $parent[UserControl].DataContext.EditCommand}"
                                                CommandParameter="{Binding}" />
                                        <Button Classes="card-btn" Content="&#x21A1; Zuweisen"
                                                Command="{Binding $parent[UserControl].DataContext.AssignCommand}"
                                                CommandParameter="{Binding}" />
                                        <Button Classes="danger" Content="&#x2715; Loeschen"
                                                Command="{Binding $parent[UserControl].DataContext.DeleteCommand}"
                                                CommandParameter="{Binding}" />
                                    </StackPanel>

                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- ===== EMPTY STATE: keine Tags ===== -->
                <Border IsVisible="{Binding Tags.Count, Converter={x:Static vm:ZeroToBoolConverter.Instance}}"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Background="#0c0c10" CornerRadius="20" Padding="40"
                        BorderBrush="#15ff6600" BorderThickness="1" Margin="20">
                    <StackPanel Orientation="Vertical" Spacing="12" HorizontalAlignment="Center">
                        <TextBlock Text="&#x1F3F7;&#xFE0F;" FontSize="48" HorizontalAlignment="Center" />
                        <TextBlock Text="Keine Tags angelegt" FontFamily="Space Grotesk, sans-serif"
                                   FontSize="16" FontWeight="SemiBold" Foreground="#e8e8ed"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="Klicke auf &quot;+ Tag hinzufuegen&quot; um einen NFC- oder QR-Tag anzulegen."
                                   FontFamily="Inter, sans-serif" FontSize="12" Foreground="#7a7a8a"
                                   TextWrapping="Wrap" TextAlignment="Center" MaxWidth="300" />
                    </StackPanel>
                </Border>
            </Panel>
        </ScrollViewer>
    </Grid>
</UserControl>