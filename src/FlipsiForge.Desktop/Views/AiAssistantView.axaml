<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FlipsiForge.Desktop.ViewModels"
             x:Class="FlipsiForge.Desktop.Views.AiAssistantView"
             x:CompileBindings="False"
             Background="Transparent">

    <UserControl.DataContext>
        <vm:AiAssistantViewModel />
    </UserControl.DataContext>

    <!-- Keine lokalen Styles mehr — globale Styles aus App.axaml greifen automatisch.
         .usermsg / .botmsg Bento-Style Farben hier inline. -->

    <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="16">

        <!-- Header (TechFlipsi: ember header, Space Grotesk) -->
        <Border Grid.Row="0" Background="#0a0a0f" CornerRadius="12" Padding="16,12"
                BorderBrush="#15ff6600" BorderThickness="1" Margin="0,0,0,10">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <TextBlock Text="🤖 Drucker-Assistent" FontFamily="Space Grotesk, sans-serif"
                               Foreground="#ff6600" FontWeight="Bold"
                               FontSize="18" VerticalAlignment="Center" />
                    <Border Classes="badge" VerticalAlignment="Center">
                        <TextBlock Text="{Binding ModelBadge}" Foreground="#7a7a8a" FontSize="11"
                                   VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Banner: KI deaktiviert (Bento-Style) -->
        <Border Grid.Row="1" Classes="bento-sm" IsVisible="{Binding AiDisabled}" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock Text="⚠️" FontSize="18" VerticalAlignment="Center" />
                <TextBlock Text="KI ist in Einstellungen deaktiviert — aktivieren zum Nutzen"
                           Foreground="#e8e8ed" VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Banner: Modell nicht geladen (Bento-Style) -->
        <Border Grid.Row="1" Classes="bento-sm"
                IsVisible="{Binding ModelNotLoaded}" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <TextBlock Text="💡" FontSize="18" VerticalAlignment="Center" />
                <TextBlock Text="KI-Modell nicht geladen." Foreground="#e8e8ed" VerticalAlignment="Center" />
                <Button Classes="primary" Content="Modell konfigurieren"
                        Command="{Binding ConfigureModelCommand}" />
            </StackPanel>
        </Border>

        <!-- Chat-Verlauf (Bento-Card Container) -->
        <Border Grid.Row="2" Classes="bento-sm" Margin="0,0,0,10">
            <ScrollViewer x:Name="ChatScroll">
                <ItemsControl ItemsSource="{Binding Messages}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:ChatRowVm}">
                            <Panel>
                                <!-- User (rechts) — Bento-Style Farbe: surface-2 bg, ember border -->
                                <Border IsVisible="{Binding IsUser}"
                                        Background="#111116" BorderBrush="#15ff6600" BorderThickness="1"
                                        CornerRadius="12" Padding="12,8"
                                        HorizontalAlignment="Right" MaxWidth="500"
                                        Margin="0,4,40,4">
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="{Binding Content}" Foreground="#e8e8ed" TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding TimeDisplay}" Foreground="#7a7a8a" FontSize="10"
                                                   HorizontalAlignment="Right" />
                                    </StackPanel>
                                </Border>
                                <!-- AI (links) — Bento-Style Farbe: surface bg, ember accent border -->
                                <Border IsVisible="{Binding IsAssistant}"
                                        Background="#0c0c10" BorderBrush="#ff6600" BorderThickness="1"
                                        CornerRadius="12" Padding="12,8"
                                        HorizontalAlignment="Left" MaxWidth="500"
                                        Margin="40,4,0,4">
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="{Binding Content}" Foreground="#e8e8ed" TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding TimeDisplay}" Foreground="#ff6600" FontSize="10"
                                                   HorizontalAlignment="Left" />
                                    </StackPanel>
                                </Border>
                            </Panel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Eingabe (pill-shaped Send-Button via globale Button-Styles) -->
        <Grid Grid.Row="3" ColumnDefinitions="*,Auto,Auto">
            <TextBox Grid.Column="0" Text="{Binding Input}" PlaceholderText="Frage an den Drucker-Assistenten..."
                     KeyUp="Input_KeyUp" />
            <TextBlock Grid.Column="1" Text="…" FontSize="20" Foreground="#ff6600"
                       VerticalAlignment="Center" Margin="10,0,0,0"
                       IsVisible="{Binding IsGenerating}" />
            <Button Grid.Column="2" Classes="primary" Content="Senden"
                    Command="{Binding SendCommand}" Margin="8,0,0,0"
                    IsEnabled="{Binding !IsGenerating}" />
        </Grid>
    </Grid>
</UserControl>