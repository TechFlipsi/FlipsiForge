<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FlipsiForge.Desktop.ViewModels"
             x:Class="FlipsiForge.Desktop.Views.AiAssistantView"
             x:CompileBindings="False"
             Background="Transparent">

    <UserControl.DataContext>
        <vm:AiAssistantViewModel />
    </UserControl.DataContext>

    <UserControl.Styles>
        <Style Selector="Button">
            <Setter Property="Background" Value="#1a1a2e" />
            <Setter Property="Foreground" Value="#fff" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="12,8" />
        </Style>
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="#ff6600" />
            <Setter Property="Foreground" Value="#050507" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>
        <Style Selector="TextBox">
            <Setter Property="Background" Value="#0a0a0f" />
            <Setter Property="BorderBrush" Value="#1a1a2e" />
            <Setter Property="Foreground" Value="#fff" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="10,8" />
        </Style>
        <Style Selector="Border.usermsg">
            <Setter Property="Background" Value="#1a1a2e" />
            <Setter Property="BorderBrush" Value="#1a1a2e" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="MaxWidth" Value="500" />
            <Setter Property="Margin" Value="0,4,40,4" />
        </Style>
        <Style Selector="Border.aimsg">
            <Setter Property="Background" Value="#0a0a0f" />
            <Setter Property="BorderBrush" Value="#ff6600" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="MaxWidth" Value="500" />
            <Setter Property="Margin" Value="40,4,0,4" />
        </Style>
        <Style Selector="Border.banner">
            <Setter Property="Background" Value="#3a1a1a" />
            <Setter Property="BorderBrush" Value="#ff6600" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="16">

        <!-- Header -->
        <Border Grid.Row="0" Background="#0a0a0f" CornerRadius="6" Padding="14,10" Margin="0,0,0,10">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <TextBlock Text="🤖 Drucker-Assistent" Foreground="#ff6600" FontWeight="Bold"
                               FontSize="18" VerticalAlignment="Center" />
                    <Border Background="#1a1a2e" CornerRadius="10" Padding="10,3">
                        <TextBlock Text="{Binding ModelBadge}" Foreground="#aaa" FontSize="11"
                                   VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Banner: KI deaktiviert -->
        <Border Grid.Row="1" Classes="banner" IsVisible="{Binding AiDisabled}">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock Text="⚠️" FontSize="18" VerticalAlignment="Center" />
                <TextBlock Text="KI ist in Einstellungen deaktiviert — aktivieren zum Nutzen"
                           Foreground="#fff" VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Banner: Modell nicht geladen -->
        <Border Grid.Row="1" Classes="banner"
                IsVisible="{Binding ModelNotLoaded}"
                Background="#0a0a0f">
            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <TextBlock Text="💡" FontSize="18" VerticalAlignment="Center" />
                <TextBlock Text="KI-Modell nicht geladen." Foreground="#fff" VerticalAlignment="Center" />
                <Button Content="Modell konfigurieren" Classes="primary"
                        Command="{Binding ConfigureModelCommand}"
                        Padding="10,4" FontSize="12" />
            </StackPanel>
        </Border>

        <!-- Chat-Verlauf -->
        <Border Grid.Row="2" Background="#050507" BorderBrush="#1a1a2e" BorderThickness="1"
                CornerRadius="6" Margin="0,0,0,10">
            <ScrollViewer x:Name="ChatScroll" Padding="8">
                <ItemsControl ItemsSource="{Binding Messages}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:ChatRowVm}">
                            <Panel>
                                <!-- User (rechts) -->
                                <Border Classes="usermsg" IsVisible="{Binding IsUser}">
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="{Binding Content}" Foreground="#fff" TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding TimeDisplay}" Foreground="#666" FontSize="10"
                                                   HorizontalAlignment="Right" />
                                    </StackPanel>
                                </Border>
                                <!-- AI (links) -->
                                <Border Classes="aimsg" IsVisible="{Binding IsAssistant}">
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="{Binding Content}" Foreground="#fff" TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding TimeDisplay}" Foreground="#ff6600" FontSize="10"
                                                   HorizontalAlignment="Left" />
                                    </StackPanel>
                                </Border>
                            </Panel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Eingabe -->
        <Grid Grid.Row="3" ColumnDefinitions="*,Auto,Auto">
            <TextBox Grid.Column="0" Text="{Binding Input}" PlaceholderText="Frage an den Drucker-Assistenten..."
                     KeyUp="Input_KeyUp" />
            <TextBlock Grid.Column="1" Text="…" FontSize="20" Foreground="#ff6600"
                       VerticalAlignment="Center" Margin="10,0,0,0"
                       IsVisible="{Binding IsGenerating}" />
            <Button Grid.Column="2" Classes="primary" Content="Senden"
                    Command="{Binding SendCommand}" Margin="8,0,0,0"
                    IsEnabled="{Binding !IsGenerating}" />
        </Grid>
    </Grid>
</UserControl>