<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FlipsiForge.Desktop.ViewModels"
             x:Class="FlipsiForge.Desktop.Views.DruckWaechterView"
             x:CompileBindings="False"
             Background="Transparent">

    <UserControl.DataContext>
        <vm:DruckWaechterViewModel />
    </UserControl.DataContext>

    <UserControl.Styles>
        <!-- ===== BENTO CARD ===== -->
        <Style Selector="Border.bento-card">
            <Setter Property="Background" Value="#0c0c10" />
            <Setter Property="BorderBrush" Value="#15ff6600" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="20" />
            <Setter Property="Padding" Value="24" />
            <Setter Property="BoxShadow" Value="0 4px 16px #00000022" />
        </Style>
        <Style Selector="Border.bento-card:pointerover">
            <Setter Property="BorderBrush" Value="#40ff6600" />
            <Setter Property="BoxShadow" Value="0 12px 40px #00000055" />
        </Style>

        <!-- ===== STATUS DOT ===== -->
        <Style Selector="Ellipse.status-dot">
            <Setter Property="Width" Value="8" />
            <Setter Property="Height" Value="8" />
        </Style>

        <!-- ===== TOGGLE SWITCH ===== -->
        <Style Selector="ToggleSwitch.tswitch">
            <Setter Property="MinWidth" Value="52" />
            <Setter Property="OnContent" Value="" />
            <Setter Property="OffContent" Value="" />
        </Style>

        <!-- ===== FILAMENT BUTTON ===== -->
        <Style Selector="Button.filament-btn">
            <Setter Property="Background" Value="#111116" />
            <Setter Property="BorderBrush" Value="#12ff6600" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Padding" Value="20,10" />
            <Setter Property="Foreground" Value="#ff8533" />
            <Setter Property="FontFamily" Value="Space Grotesk, sans-serif" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="Button.filament-btn:pointerover">
            <Setter Property="Background" Value="#18181f" />
            <Setter Property="BorderBrush" Value="#40ff6600" />
            <Setter Property="Foreground" Value="#e8e8ed" />
        </Style>
        <Style Selector="Button.filament-btn:disabled">
            <Setter Property="Opacity" Value="0.35" />
        </Style>

        <!-- ===== TEMP BAR ===== -->
        <Style Selector="ProgressBar.temp-bar">
            <Setter Property="Height" Value="4" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Background" Value="#18181f" />
            <Setter Property="Foreground" Value="#ff6600" />
            <Setter Property="MinHeight" Value="4" />
        </Style>

        <!-- ===== MODAL ===== -->
        <Style Selector="Border.modal-card">
            <Setter Property="Background" Value="#0c0c10" />
            <Setter Property="BorderBrush" Value="#40ff6600" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="20" />
            <Setter Property="Padding" Value="24" />
            <Setter Property="BoxShadow" Value="0 24px 60px #00000066" />
        </Style>
        <Style Selector="Border.modal-item">
            <Setter Property="Background" Value="#111116" />
            <Setter Property="BorderBrush" Value="#15ff6600" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>
        <Style Selector="Border.modal-item:pointerover">
            <Setter Property="Background" Value="#18181f" />
            <Setter Property="BorderBrush" Value="#40ff6600" />
        </Style>

        <!-- ===== MODAL BUTTON ===== -->
        <Style Selector="Button.modal-btn">
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Padding" Value="20,10" />
            <Setter Property="FontFamily" Value="Space Grotesk, sans-serif" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="Button.modal-btn.cancel">
            <Setter Property="Background" Value="#08ffffff" />
            <Setter Property="BorderBrush" Value="#10ffffff" />
            <Setter Property="Foreground" Value="#7a7a8a" />
        </Style>
        <Style Selector="Button.modal-btn.confirm">
            <Setter Property="Background" Value="#22ff6600" />
            <Setter Property="BorderBrush" Value="#25ff6600" />
            <Setter Property="Foreground" Value="#ff8533" />
        </Style>
        <Style Selector="Button.modal-btn.confirm:pointerover">
            <Setter Property="Background" Value="#40ff6600" />
            <Setter Property="Foreground" Value="#e8e8ed" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*">
        <!-- ===== HEADER ===== -->
        <Border Grid.Row="0" Background="#0a0a0f" CornerRadius="6" Padding="16,12" Margin="16,16,16,8">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <TextBlock Grid.Column="0" Text="🛡️ DruckWächter" Foreground="#ff6600" FontWeight="Bold"
                           FontSize="18" VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" Text="{Binding Cards.Count, StringFormat='{}{0} Drucker überwacht'}"
                           Foreground="#666" FontSize="12" VerticalAlignment="Center" Margin="16,0,0,0" />
            </Grid>
        </Border>

        <!-- ===== DRUCKER CARDS ===== -->
        <ScrollViewer Grid.Row="1" Padding="16" HorizontalScrollBarVisibility="Disabled">
            <Panel>
                <ItemsControl ItemsSource="{Binding Cards}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" ItemWidth="400" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:DruckWaechterCardVm}">
                        <Border Classes="bento-card" Margin="0,0,16,16" Width="380">
                            <StackPanel Orientation="Vertical" Spacing="14">

                                <!-- ===== CARD HEADER ===== -->
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="🖨️" FontSize="24" VerticalAlignment="Center" />
                                    <StackPanel Orientation="Vertical" Spacing="2">
                                        <TextBlock Text="{Binding Name}" FontFamily="Space Grotesk, sans-serif"
                                                   FontSize="16" FontWeight="SemiBold" Foreground="#e8e8ed" />
                                        <TextBlock Text="{Binding Description}" FontSize="11" Foreground="#7a7a8a" />
                                    </StackPanel>
                                </StackPanel>

                                <!-- ===== STATUS ROW ===== -->
                                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,2">
                                    <Ellipse Classes="status-dot" Fill="#55555f" />
                                    <TextBlock Text="{Binding StatusText}" FontFamily="Space Grotesk, sans-serif"
                                               FontSize="12" FontWeight="SemiBold" Foreground="#e8e8ed"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding PowerW, StringFormat='{}{0:F1}W'}"
                                               FontFamily="Space Grotesk, sans-serif" FontSize="13"
                                               FontWeight="SemiBold" Foreground="#ff8533"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Right" />
                                </StackPanel>

                                <!-- ===== TOGGLE SWITCHES ===== -->
                                <StackPanel Orientation="Vertical" Spacing="10" Margin="0,4">
                                    <!-- Drucker (Shelly) Toggle -->
                                    <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center">
                                        <TextBlock Text="Drucker" FontFamily="Space Grotesk, sans-serif"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   Foreground="#7a7a8a" Width="60"
                                                   TextAlignment="Right" VerticalAlignment="Center" />
                                        <ToggleSwitch Classes="tswitch" IsChecked="{Binding IsShellyOn}"
                                                      IsEnabled="{Binding HasShelly}" />
                                        <TextBlock Text="{Binding IsShellyOn, StringFormat='{}{0:AN;AUS}'}"
                                                   FontFamily="Space Grotesk, sans-serif" FontSize="12"
                                                   FontWeight="SemiBold" Foreground="#7a7a8a"
                                                   Width="30" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <!-- Licht Toggle -->
                                    <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center">
                                        <TextBlock Text="Licht" FontFamily="Space Grotesk, sans-serif"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   Foreground="#7a7a8a" Width="60"
                                                   TextAlignment="Right" VerticalAlignment="Center" />
                                        <ToggleSwitch Classes="tswitch" IsChecked="{Binding IsLightOn}"
                                                      IsEnabled="{Binding HasLightMacro}" />
                                        <TextBlock Text="{Binding IsLightOn, StringFormat='{}{0:AN;AUS}'}"
                                                   FontFamily="Space Grotesk, sans-serif" FontSize="12"
                                                   FontWeight="SemiBold" Foreground="#7a7a8a"
                                                   Width="30" VerticalAlignment="Center" />
                                    </StackPanel>
                                </StackPanel>

                                <!-- ===== FILAMENT BUTTONS ===== -->
                                <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center" Margin="0,4">
                                    <Button Classes="filament-btn" Content="📥 Filament Laden"
                                            IsEnabled="{Binding HasFilamentMacro}"
                                            Command="{Binding #parent.((vm:DruckWaechterViewModel)DataContext).ShowLoadFilamentCommand}"
                                            CommandParameter="{Binding}" />
                                    <Button Classes="filament-btn" Content="📤 Filament Entladen"
                                            IsEnabled="{Binding HasFilamentMacro}"
                                            Command="{Binding #parent.((vm:DruckWaechterViewModel)DataContext).ShowUnloadFilamentCommand}"
                                            CommandParameter="{Binding}" />
                                </StackPanel>

                                <!-- ===== TEMPERATURES ===== -->
                                <Border BorderBrush="#15ff6600" BorderThickness="0,1,0,0" Padding="0,12,0,0" Margin="0,4">
                                    <StackPanel Orientation="Vertical" Spacing="8">
                                        <TextBlock Text="TEMPERATUREN" FontFamily="Space Grotesk, sans-serif"
                                                   FontSize="10" FontWeight="SemiBold" Foreground="#55555f"
                                                   HorizontalAlignment="Center" />

                                        <!-- Extruder Temps -->
                                        <ItemsControl ItemsSource="{Binding ExtruderTemps}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type vm:TempRowVm}">
                                                    <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,2">
                                                        <TextBlock Text="{Binding Label}" FontSize="11"
                                                                   Foreground="#7a7a8a" Width="70"
                                                                   VerticalAlignment="Center" />
                                                        <ProgressBar Classes="temp-bar" Value="{Binding BarPercent}"
                                                                     Maximum="100" Width="160" />
                                                        <TextBlock Text="{Binding DisplayTemp}"
                                                                   FontFamily="Space Grotesk, sans-serif"
                                                                   FontSize="12" FontWeight="SemiBold"
                                                                   Foreground="#e8e8ed" Width="50"
                                                                   TextAlignment="Right" VerticalAlignment="Center" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!-- Bed Temps -->
                                        <ItemsControl ItemsSource="{Binding BedTemps}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type vm:TempRowVm}">
                                                    <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,2">
                                                        <TextBlock Text="{Binding Label}" FontSize="11"
                                                                   Foreground="#7a7a8a" Width="70"
                                                                   VerticalAlignment="Center" />
                                                        <ProgressBar Classes="temp-bar" Value="{Binding BarPercent}"
                                                                     Maximum="100" Width="160" />
                                                        <TextBlock Text="{Binding DisplayTemp}"
                                                                   FontFamily="Space Grotesk, sans-serif"
                                                                   FontSize="12" FontWeight="SemiBold"
                                                                   Foreground="#e8e8ed" Width="50"
                                                                   TextAlignment="Right" VerticalAlignment="Center" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>

                                <!-- ===== FOOTER ===== -->
                                <Border BorderBrush="#15ff6600" BorderThickness="0,1,0,0" Padding="0,10,0,0" Margin="0,4">
                                    <TextBlock Text="{Binding LastPrintInfo}" FontSize="11"
                                               Foreground="#55555f" HorizontalAlignment="Center"
                                               TextAlignment="Center" />
                                </Border>

                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Empty State: keine Drucker -->
            <Border IsVisible="{Binding HasNoPrinters}"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Background="#0c0c10" CornerRadius="20" Padding="40"
                    BorderBrush="#15ff6600" BorderThickness="1" Margin="20">
                <StackPanel Orientation="Vertical" Spacing="12" HorizontalAlignment="Center">
                    <TextBlock Text="🛡️" FontSize="48" HorizontalAlignment="Center" />
                    <TextBlock Text="Keine Drucker konfiguriert"
                               FontFamily="Space Grotesk, sans-serif" FontSize="16"
                               FontWeight="SemiBold" Foreground="#e8e8ed"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Füge zuerst Drucker im Drucker-Tab hinzu, damit der DruckWächter sie überwachen kann."
                               FontSize="12" Foreground="#7a7a8a"
                               TextWrapping="Wrap" TextAlignment="Center" MaxWidth="300" />
                </StackPanel>
            </Border>
            </Panel>
        </ScrollViewer>

        <!-- ===== FILAMENT POPUP MODAL ===== -->
        <Border Grid.Row="0" Grid.RowSpan="2" Background="#80050507"
                IsVisible="{Binding IsFilamentPopupOpen}"
                ZIndex="1000">
            <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Width="380">
                <Border Classes="modal-card">
                    <StackPanel Orientation="Vertical" Spacing="16">
                        <!-- Title -->
                        <TextBlock Text="{Binding PopupTitle}" FontFamily="Space Grotesk, sans-serif"
                                   FontSize="15" FontWeight="SemiBold" Foreground="#ff6600"
                                   HorizontalAlignment="Center" TextAlignment="Center" />

                        <!-- Extruder-Auswahl (nur bei Multi-Extruder) -->
                        <ItemsControl ItemsSource="{Binding PopupCard.ExtruderTemps}" IsVisible="{Binding PopupCard.IsMultiExtruder}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:TempRowVm}">
                                    <Border Classes="modal-item">
                                        <StackPanel Orientation="Horizontal" Spacing="10">
                                            <TextBlock Text="{Binding Label}" FontFamily="Space Grotesk, sans-serif"
                                                       FontSize="13" Foreground="#e8e8ed" />
                                            <TextBlock Text="{Binding DisplayTemp}" FontFamily="Space Grotesk, sans-serif"
                                                       FontSize="12" Foreground="#7a7a8a"
                                                       HorizontalAlignment="Right" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Buttons -->
                        <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,8,0,0">
                            <Button Classes="modal-btn cancel" Content="Abbrechen" HorizontalAlignment="Stretch"
                                    Command="{Binding CloseFilamentPopupCommand}" />
                            <Button Classes="modal-btn confirm" Content="{Binding PopupIsLoad, StringFormat='{}{0:Laden;Entladen}'}"
                                    HorizontalAlignment="Stretch"
                                    Command="{Binding ConfirmFilamentCommand}" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

    </Grid>
</UserControl>