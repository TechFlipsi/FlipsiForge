<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:FlipsiForge.Desktop.ViewModels"
        xmlns:views="using:FlipsiForge.Desktop.Views"
        x:Class="FlipsiForge.Desktop.MainWindow"
        x:CompileBindings="False"
        Title="FlipsiForge v0.4.1"
        Width="1280" Height="800"
        MinWidth="1024" MinHeight="600"
        Background="#050507"
        WindowStartupLocation="CenterScreen"
        Icon="avares://FlipsiForge.Desktop/Assets/flipsiforge.ico">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid ColumnDefinitions="220,*">
        <!-- ===== LINKE SIDEBAR ===== -->
        <Border Grid.Column="0" Background="#0a0a0f" BorderBrush="#15ff6600" BorderThickness="0,0,1,0">
            <Grid RowDefinitions="Auto,*,Auto">
                <!-- Header: Logo-Emblem + FlipsiForge -->
                <Border Grid.Row="0" Padding="16,14" Background="#050507" BorderBrush="#15ff6600" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Vertical" Spacing="2">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Image Source="avares://FlipsiForge.Desktop/Assets/logo-emblem.png"
                                   Width="28" Height="28" VerticalAlignment="Center" />
                            <TextBlock Text="FlipsiForge" FontFamily="Space Grotesk, sans-serif"
                                       FontSize="18" FontWeight="Bold"
                                       Foreground="#ff6600" VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock Text="{Binding AppVersion}" FontFamily="Space Grotesk, sans-serif"
                                   FontSize="11" Foreground="#55555f"
                                   Margin="38,0,0,0" />
                    </StackPanel>
                </Border>

                <!-- Nav-Buttons als ListBox -->
                <ListBox Grid.Row="1"
                         x:Name="NavList"
                         ItemsSource="{Binding NavItems}"
                         Background="Transparent"
                         BorderThickness="0"
                         Padding="8,8,8,0"
                         SelectionChanged="NavList_SelectionChanged">
                    <ListBox.ItemContainerTheme>
                        <ControlTheme TargetType="{x:Type ListBoxItem}" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                            <Setter Property="Padding" Value="16,12" />
                            <Setter Property="Margin" Value="0,2" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Foreground" Value="#7a7a8a" />
                            <Setter Property="FontFamily" Value="Space Grotesk, sans-serif" />
                            <Setter Property="FontSize" Value="14" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="CornerRadius" Value="8" />
                            <Setter Property="(ToolTip.Tip)" Value="{Binding Name}" />
                            <Style Selector="^:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                                <Setter Property="Background" Value="#18181f" />
                                <Setter Property="Foreground" Value="#e8e8ed" />
                            </Style>
                            <Style Selector="^:selected /template/ ContentPresenter#PART_ContentPresenter">
                                <Setter Property="Background" Value="#22ff6600" />
                                <Setter Property="Foreground" Value="#ff6600" />
                            </Style>
                        </ControlTheme>
                    </ListBox.ItemContainerTheme>
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:NavItem}">
                            <TextBlock Text="{Binding DisplayText}" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Settings-Button unten -->
                <Border Grid.Row="2" Padding="8,8" Background="#050507" BorderBrush="#15ff6600" BorderThickness="0,1,0,0">
                    <Button Background="Transparent"
                            Foreground="#7a7a8a"
                            BorderThickness="0"
                            CornerRadius="8"
                            Padding="16,12"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            FontFamily="Space Grotesk, sans-serif"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Command="{Binding OpenSettingsCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="⚙️" FontSize="16" VerticalAlignment="Center" />
                            <TextBlock Text="Einstellungen" FontSize="14" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </Border>
            </Grid>
        </Border>

        <!-- ===== RECHTER CONTENT ===== -->
        <Grid Grid.Column="1" Background="#050507">
            <!-- Content-Bereich (vom MainViewModel gesetzt) -->
            <ContentControl Content="{Binding CurrentView}" />

            <!-- Forge-Bot Overlay (immer da, über Content) -->
            <views:ForgeBotView Width="140" Height="180"
                                VerticalAlignment="Bottom"
                                HorizontalAlignment="Right"
                                Margin="0,0,10,10"
                                IsHitTestVisible="True"
                                DataContext="{Binding ForgeBot}" />

            <!-- ===== SETTINGS OVERLAY ===== -->
            <Border Background="#80000000"
                    IsVisible="{Binding IsSettingsOpen}"
                    ZIndex="100">
                <Grid Margin="40">
                    <Border Background="#0a0a0f"
                            CornerRadius="20"
                            BorderBrush="#40ff6600"
                            BorderThickness="1"
                            BoxShadow="0 24px 60px #00000066">
                        <Grid RowDefinitions="Auto,*">
                            <!-- Settings-Header -->
                            <Border Grid.Row="0" Background="#050507" Padding="24,16"
                                    BorderBrush="#15ff6600" BorderThickness="0,0,0,1">
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                                        <TextBlock Text="⚙️" FontSize="24" VerticalAlignment="Center" />
                                        <TextBlock Text="Einstellungen" FontFamily="Space Grotesk, sans-serif"
                                                   FontSize="20" FontWeight="Bold"
                                                   Foreground="#ff6600" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="✕ Schließen"
                                            Command="{Binding CloseSettingsCommand}" />
                                </Grid>
                            </Border>
                            <!-- Settings-Inhalt -->
                            <ScrollViewer Grid.Row="1" Padding="24">
                                <views:SettingsView DataContext="{Binding Settings}" />
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>